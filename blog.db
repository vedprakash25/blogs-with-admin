INSERT INTO blogs (
  title, slug, excerpt, content, cover_image,
  category_id, author_id,
  status, published_at,
  meta_title, meta_description
) VALUES

(
'Animations in React with Framer Motion + TypeScript',
'react-animations-framer-motion-typescript',
'Create fluid, performant animations with Framer Motion and TypeScript from simple fades to complex gesture-driven interactions.',
'{
 "blocks":[
  {
   "type":"heading",
   "level":2,
   "text":"Animations in React with Framer Motion + TypeScript"
  },
  {
   "type":"paragraph",
   "text":"Animations guide users, provide feedback, and make interfaces feel alive. Poorly implemented animations however create lag and degrade user experience."
  },
  {
   "type":"paragraph",
   "text":"Framer Motion combined with TypeScript enables smooth, declarative animations while maintaining strong type safety."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Why Framer Motion"
  },
  {
   "type":"code",
   "language":"bash",
   "code":"npm install framer-motion"
  },
  {
   "type":"paragraph",
   "text":"Framer Motion provides a simple API, powerful animation primitives, gesture support, and excellent TypeScript compatibility."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Basic Animation Example"
  },
  {
   "type":"code",
   "language":"typescript",
   "code":"import { motion } from ''framer-motion'';\n\nconst FadeInBox = () => {\n  return (\n    <motion.div\n      initial={{ opacity: 0, y: 20 }}\n      animate={{ opacity: 1, y: 0 }}\n      transition={{ duration: 0.5 }}\n    >\n      I animate smoothly\n    </motion.div>\n  );\n};"
  },
  {
   "type":"paragraph",
   "text":"Framer Motion automatically types animation properties, giving developers strong autocomplete and type inference."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Variants for Reusable Animations"
  },
  {
   "type":"paragraph",
   "text":"Variants allow developers to define reusable animation states that can be shared across components."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Performance Best Practices"
  },
  {
   "type":"list",
   "items":[
    "Prefer transform properties like translate, scale, and rotate.",
    "Avoid layout-affecting properties like width and height.",
    "Use hardware-accelerated transforms whenever possible.",
    "Use animation libraries like Framer Motion that optimize updates."
   ]
  },
  {
   "type":"heading",
   "level":2,
   "text":"Key Takeaways"
  },
  {
   "type":"list",
   "items":[
    "Framer Motion offers powerful declarative animation APIs.",
    "TypeScript improves reliability of animation props.",
    "Variants keep animation logic reusable and organized.",
    "Performance-friendly transforms ensure smooth animations."
   ]
  }
 ]
}',
'https://picsum.photos/1200/500?random=8',
NULL,
NULL,
'published',
'2026-03-08',
'Animations in React with Framer Motion + TypeScript',
'Learn how to create smooth animations in React using Framer Motion with TypeScript support.'
),

(
'Building a Dark Mode Toggle with Context and localStorage',
'react-dark-mode-context-localstorage',
'Create a seamless dark mode experience with React Context, persistent storage, and zero flash on page load.',
'{
 "blocks":[
  {
   "type":"heading",
   "level":2,
   "text":"Building a Dark Mode Toggle with Context and localStorage"
  },
  {
   "type":"paragraph",
   "text":"Dark mode is now a standard feature in modern applications. Users expect a theme toggle that persists their preference across sessions."
  },
  {
   "type":"paragraph",
   "text":"A proper implementation must avoid the flash of incorrect theme during page load."
  },
  {
   "type":"heading",
   "level":2,
   "text":"The Flash of Light Problem"
  },
  {
   "type":"paragraph",
   "text":"Many applications initialize the theme state in React after the first render, causing a flash of light theme before dark theme loads."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Creating a Theme Context"
  },
  {
   "type":"code",
   "language":"typescript",
   "code":"type Theme = ''light'' | ''dark'';\n\nconst ThemeContext = createContext();"
  },
  {
   "type":"paragraph",
   "text":"Using React Context allows the theme state to be shared across the entire application."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Persisting the Theme"
  },
  {
   "type":"paragraph",
   "text":"LocalStorage stores the user's preference so the application can restore it on the next visit."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Preventing Theme Flash"
  },
  {
   "type":"paragraph",
   "text":"A small inline script executed before React hydrates can read the stored theme and apply the correct class to the document element."
  },
  {
   "type":"heading",
   "level":2,
   "text":"Key Takeaways"
  },
  {
   "type":"list",
   "items":[
    "Use React Context to manage theme globally.",
    "Persist user preference using localStorage.",
    "Inject an early script to prevent theme flash.",
    "Respect system preferences using prefers-color-scheme."
   ]
  }
 ]
}',
'https://picsum.photos/1200/500?random=8',
NULL,
NULL,
'published',
'2026-03-08',
'Dark Mode Toggle in React using Context',
'Learn how to implement a persistent dark mode toggle in React using Context and localStorage.'
),
